# kibana.yaml
apiVersion: kibana.k8s.elastic.co/v1
kind: Kibana
metadata:
  name: kibana
  namespace: eck
spec:
  version: 9.0.3
  count: 1
  elasticsearchRef:
    name: elasticsearch-cluster
  http:
    service:
      spec:
        type: ClusterIP
    tls:
      selfSignedCertificate:
        disabled: false
  podTemplate:
    spec:
      containers:
      - name: kibana
        resources:
          requests:
            memory: 1Gi
            cpu: 0.5
          limits:
            memory: 2Gi
            cpu: 2
        env:
        - name: NODE_OPTIONS
          value: "--max-old-space-size=1800"
      nodeSelector:
        kubernetes.io/os: linux

